  abstract class CareerPageFetcherFactory {
    +createFetcher()
  }

  class TailoredResumeBuilder {
    +summary()
    +skills()
    +build()
  }
}

package "Design Patterns - Structural" #FFF3E0 {
  class ResumeTailoringFacade {
    +tailor()
  }

  class CachingCareerPageProxy {
    +fetch()
  }

  class MatchScoreJobDecorator {
    -matchPercent: int
  }
}

package "Design Patterns - Behavioral" #F1F8E9 {
  class CompanyWatchSubject {
    +subscribe()
    +notifyNewJob()
  }

  class ApplicationTrackerContext {
    -state: ApplicationState
  }

  class JobIngestionMediator {
    +pollWatch()
  }

  class ResumeValidationHandler {
    +validate()
  }
}

package "AI Integration" #EDE7F6 {
  interface ResumeGenerator {
    +generate(job, baseResume): TailoredResumeContent
  }

  class LLMResumeGenerator {
    -client: OpenAiClient
    +generate(job, baseResume): TailoredResumeContent
  }

  class OpenAiClient {
    +tailor(jobTitle, companyName, description, base): TailoredResumeContent
  }
}

