' Controller/Service DTO Boundary
package "Backend - DTOs (API Contracts)" #E0F7FA {
  class RegisterRequest <<record>>
  class LoginRequest <<record>>
  class AuthResponse <<record>>
  class CreateCompanyWatchRequest <<record>>
  class CompanyWatchResponse <<record>>
  class JobPostingResponse <<record>>
  class SaveBaseResumeRequest <<record>>
  class BaseResumeResponse <<record>>
  class TailoredResumeResponse <<record>>
  class TailoredResumeDetailResponse <<record>>
  class UpdateApplicationStatusRequest <<record>>
}

' Backend Services
package "Backend - Services" #F3E5F5 {
  class AuthService {
    +register()
    +login()
  }

  class CompanyWatchService {
    +list()
    +create()
    +poll()
  }

  class JobPostingService {
    +list()
    +get()
  }

  class ResumeService {
    +generateForJob()
    +saveTailoredResume()
  }
