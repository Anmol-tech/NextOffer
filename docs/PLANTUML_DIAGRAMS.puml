@startuml NextOffer_Factory_Pattern_Detail
title Factory Pattern - Career Page Fetcher Creation
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #E8F5E9
skinparam classBorderColor #43A047

enum AtsType {
  GREENHOUSE
  WORKDAY
  SMART_RECRUITERS
}

interface CareerPageFetcher {
  +fetch(url: String): String
}

class GreenhouseFetcher {
  +fetch(url: String): String
}

class WorkdayFetcher {
  +fetch(url: String): String
}

class SmartRecruitersFetcher {
  +fetch(url: String): String
}

abstract class CareerPageFetcherFactory {
  +createFetcher(type: AtsType): CareerPageFetcher
}

class DefaultCareerPageFetcherFactory {
  +createFetcher(type: AtsType): CareerPageFetcher
}

GreenhouseFetcher ..|> CareerPageFetcher : realizes
WorkdayFetcher ..|> CareerPageFetcher : realizes
SmartRecruitersFetcher ..|> CareerPageFetcher : realizes
DefaultCareerPageFetcherFactory --|> CareerPageFetcherFactory
CareerPageFetcherFactory "1" ..> "1" CareerPageFetcher : creates
CareerPageFetcherFactory "1" ..> "1" AtsType : uses

@enduml

@startuml NextOffer_Observer_Pattern_Detail
title Observer Pattern - New Job Discovery
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #689F38

class CompanyWatchSubject {
  -listeners: List~JobDiscoveryListener~
  +subscribe(listener): void
  +unsubscribe(listener): void
  +notifyNewJob(job, watchId): void
}

interface JobDiscoveryListener {
  +onNewJobDiscovered(job, watchId): void
}

class JobDiscoveryPersistenceListener {
  -repository: JobPostingRepository
  +onNewJobDiscovered(job, watchId): void
}

class JobPollingScheduler {
  -subject: CompanyWatchSubject
  +pollEnabledWatches(): void
}

JobDiscoveryPersistenceListener ..|> JobDiscoveryListener : realizes
CompanyWatchSubject "1" o--> "0..*" JobDiscoveryListener : notifies >
JobDiscoveryPersistenceListener "1" --> "1" JobPostingRepository : persists through
JobPollingScheduler "1" --> "1" CompanyWatchSubject : triggers polling

@enduml

@startuml NextOffer_Facade_Pattern_Detail
title Facade Pattern - Resume Tailoring Simplified
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #F57C00

class ResumeTailoringFacade {
  -pipeline: AbstractTailoringPipeline
  -validationChain: ResumeValidationHandler
  -renderer: ResumeRenderer
  +tailor(job, baseResume): TailoredResumeContent
}

abstract class AbstractTailoringPipeline {
  +execute(job, baseResume): TailoredResumeContent
  #extractKeywords()
  #rewriteSummary()
}

class OpenAiTailoringPipeline {
  -client: OpenAiClient
  +execute(job, baseResume): TailoredResumeContent
}

abstract class ResumeValidationHandler {
  #next: ResumeValidationHandler
  +validate(content): void
}

class NoFabricationValidationHandler {
  #check(content): void
}

interface ResumeRenderer {
  +render(content): String
}

class LatexResumeRenderer {
  +render(content): String
}

OpenAiTailoringPipeline --|> AbstractTailoringPipeline
NoFabricationValidationHandler --|> ResumeValidationHandler
LatexResumeRenderer ..|> ResumeRenderer : realizes
ResumeTailoringFacade "1" --> "1" AbstractTailoringPipeline : uses
ResumeTailoringFacade "1" --> "1..*" ResumeValidationHandler : chains
ResumeTailoringFacade "1" --> "1" ResumeRenderer : renders

@enduml

@startuml NextOffer_State_Pattern_Detail
title State Pattern - Application Tracker Workflow
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #FCE4EC
skinparam classBorderColor #C2185B

enum ApplicationStatus {
  NEW
  VIEWED
  APPLIED
  REJECTED
}

interface ApplicationState {
  +getStatus(): ApplicationStatus
  +view(context): void
  +apply(context): void
  +reject(context): void
}

class NewApplicationState {
  +view(): moves to Viewed
  +apply(): moves to Applied
}

class ViewedApplicationState {
  +apply(): moves to Applied
}

class AppliedApplicationState {
  +reject(): moves to Rejected
}

class RejectedApplicationState {
  (final state)
}

class ApplicationTrackerContext {
  -state: ApplicationState
  -jobPosting: JobPosting
  +setState(state): void
  +transitionTo(target): void
}

NewApplicationState ..|> ApplicationState : realizes
ViewedApplicationState ..|> ApplicationState : realizes
AppliedApplicationState ..|> ApplicationState : realizes
RejectedApplicationState ..|> ApplicationState : realizes
ApplicationTrackerContext "1" o--> "1" ApplicationState : holds

@enduml

@startuml NextOffer_Chain_Pattern_Detail
title Chain of Responsibility - Resume Validation Pipeline
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #E0F2F1
skinparam classBorderColor #00897B

abstract class ResumeValidationHandler {
  #next: ResumeValidationHandler
  +linkWith(next): ResumeValidationHandler
  +validate(content): void
  #check(content): void
}

class NoFabricationValidationHandler {
  #check(content): checks for false experience
}

class AtsLengthValidationHandler {
  #check(content): validates length limits
}

class RequiredSectionsValidationHandler {
  #check(content): ensures required sections
}

class TailoredResumeContent {
  +summary: String
  +skills: List~String~
  +experienceBullets: List~String~
}

NoFabricationValidationHandler --|> ResumeValidationHandler
AtsLengthValidationHandler --|> ResumeValidationHandler
RequiredSectionsValidationHandler --|> ResumeValidationHandler
ResumeValidationHandler "1" o--> "0..1" ResumeValidationHandler : next handler >
ResumeValidationHandler "1" ..> "1" TailoredResumeContent : validates

@enduml

@startuml NextOffer_Builder_Pattern_Detail
title Builder Pattern - Tailored Resume Construction
top to bottom direction
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #7B1FA2

class TailoredResumeBuilder {
  -summary: String
  -skills: List~String~
  -bullets: List~String~
  +summary(text: String): TailoredResumeBuilder
  +addSkill(skill: String): TailoredResumeBuilder
  +addBullet(bullet: String): TailoredResumeBuilder
  +build(): TailoredResumeContent
}

class TailoredResumeContent {
  +summary: String
  +skills: List~String~
  +experienceBullets: List~String~
}

abstract class AbstractTailoringPipeline {
  #buildContent(job): TailoredResumeBuilder
  #execute(job, baseResume): TailoredResumeContent
}

TailoredResumeBuilder "1" --> "1" TailoredResumeContent : creates
AbstractTailoringPipeline "1" --> "1" TailoredResumeBuilder : uses step-by-step

@enduml

@startuml NextOffer_Watch_Polling_Flow
title Watch Polling Flow - Runtime Sequence
participant "User" as EndUser
participant "SettingsPage" as UI
participant "WatchController" as Controller
participant "WatchService" as Service
participant "JobIngestionMediator" as Mediator
participant "CompanyWatchSubject" as Subject
participant "JobDiscoveryListener" as Listener
participant "Database" as DB

EndUser -> UI: Click Poll Watch
UI -> Controller: POST /api/watches/{id}/poll
Controller -> Service: poll(id)
Service -> Mediator: pollWatch(watch, knownIds, notify)
Mediator -> Subject: Fetches new jobs
Subject -> Subject: Compares with known jobs
alt New Jobs Found
  Subject -> Listener: notifyNewJob(job)
  Listener -> DB: save(JobPosting)
  Listener --> Subject: persisted
end
Subject --> Service: newJobs[]
Service --> Controller: PollWatchResponse
Controller --> UI: Success - X new jobs
UI --> EndUser: Display results

@enduml

@startuml NextOffer_Resume_Tailoring_Flow
title Resume Tailoring Flow - Runtime Sequence
participant "User" as EndUser
participant "ResumePage" as UI
participant "ResumeController" as Controller
participant "ResumeService" as Service
participant "ResumeTailoringFacade" as Facade
participant "OpenAiPipeline" as Pipeline
participant "OpenAI API" as OpenAI
participant "ValidationChain" as Validation
participant "LatexRenderer" as Renderer
participant "PdfService" as Pdf
participant "Database" as DB

EndUser -> UI: Generate Resume for Job
UI -> Controller: POST /api/resumes/jobs/{jobId}
Controller -> Service: generateForJob(jobId)
Service -> Facade: tailor(job, baseResume)
Facade -> Pipeline: execute(job, baseResume)
Pipeline -> Pipeline: extractKeywords()
Pipeline -> OpenAI: Send job + resume
OpenAI --> Pipeline: Tailored content
Facade -> Validation: validate(content)
Validation -> Validation: Check chain
Validation --> Facade: Valid
Facade --> Service: TailoredResumeContent
Service -> Renderer: render(content)
Renderer --> Service: LaTeX source
Service -> Pdf: compile(latex)
Pdf --> Service: PDF file
Service -> DB: save(TailoredResume)
Service --> Controller: TailoredResumeResponse
Controller --> UI: Resume generated
UI --> EndUser: Download/View

@enduml

