@startuml NextOffer_Watch_Polling_Sequence
title Watch Polling Flow - Scheduler/API to New Job Persistence
actor User
participant "SettingsPage.tsx" as SettingsPage
participant "api/watches.ts" as ApiWatches
participant "CompanyWatchController" as WatchController
participant "CompanyWatchService" as WatchService
participant "CompanyWatchRepository" as WatchRepo
participant "JobPostingRepository" as JobRepo
participant "JobIngestionMediator\n<<Mediator>>" as Mediator
participant "CareerPageFetchStrategyFactory" as StrategyFactory
participant "CareerPageFetchStrategy\n<<Strategy>>" as Strategy
participant "JobWatchFilter" as Filter
participant "CompanyWatchSubject\n<<Observer Subject>>" as Subject
participant "JobDiscoveryPersistenceListener\n<<Observer>>" as Listener

User -> SettingsPage : click poll watch
SettingsPage -> ApiWatches : pollWatch(id)
ApiWatches -> WatchController : POST /api/watches/{id}/poll
WatchController -> WatchService : poll(id)
WatchService -> WatchRepo : findById(id)
WatchService -> JobRepo : find known external ids
WatchService -> Mediator : pollWatch(watch, knownIds, true)
Mediator -> StrategyFactory : forAtsType(watch.atsType)
StrategyFactory --> Mediator : Greenhouse/Workday/SmartRecruiters strategy
Mediator -> Strategy : fetchForWatch(watch)
Strategy --> Mediator : List~JobPostingDto~
Mediator -> Filter : apply(watch, fetchedJobs)
Filter --> Mediator : filtered jobs
loop for each new externalId
  Mediator -> Subject : notifyNewJob(job, watchId)
  Subject -> Listener : onNewJobDiscovered(job, watchId)
  Listener -> WatchRepo : findById(watchId)
  Listener -> JobRepo : existsByCompanyWatchIdAndExternalId(...)
  Listener -> JobRepo : save(new JobPosting(watch, job))
end
Mediator --> WatchService : newJobs
WatchService --> WatchController : PollWatchResponse
WatchController --> SettingsPage : new jobs summary
@enduml

