@startuml NextOffer_Auth_Sequence
title Authentication Flow - Register & Login
participant "AuthScreen" as UI
participant "AuthContext" as Ctx
participant "AuthController" as Ctrl
participant "AuthService" as Svc
participant "JwtService" as JWT
participant "UserRepository" as Repo
participant "Browser Storage" as Storage

UI -> Ctx: register(email, pwd, name)
Ctx -> Ctrl: POST /api/auth/register
Ctrl -> Svc: register()
Svc -> Repo: findByEmail() - check exists
alt Email exists
  Svc --> Ctrl: EmailAlreadyExistsException
else Email new
  Svc -> Repo: save(new User)
  Svc -> JWT: generateToken()
  JWT --> Svc: token
  Svc --> Ctrl: AuthResponse(token, user)
end
Ctrl --> Ctx: AuthResponse
Ctx -> Storage: setStoredToken(token)
Ctx --> UI: authenticated state
UI --> UI: navigate to Dashboard

@enduml

