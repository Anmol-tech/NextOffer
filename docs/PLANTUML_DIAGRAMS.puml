  class "Bridge\nResumeRenderer\nLatexResumeRenderer" as Bridge
  class "Composite\nResumeSectionComponent\nResumeSectionGroup\nResumeSectionLeaf" as Composite
  class "Decorator\nJobPostingDecorator\nMatchScoreJobDecorator" as Decorator
  class "Facade\nResumeTailoringFacade" as Facade
  class "Flyweight\nCompanyBrandingFlyweight\nCompanyBrandingFlyweightFactory" as Flyweight
  class "Proxy\nCachingCareerPageProxy\nCareerPageFetcher" as Proxy
}

package "Behavioral Patterns" {
  class "Observer\nCompanyWatchSubject\nJobDiscoveryListener\nJobDiscoveryPersistenceListener" as Observer
  class "Strategy\nCareerPageFetchStrategy\nGreenhouse/Workday/SmartRecruiters Strategies" as Strategy
  class "State\nApplicationTrackerContext\nApplicationState\nNew/Viewed/Applied/Rejected States" as State
  class "Command\nResumeCommand\nTailorResumeCommand\nCommandInvoker" as Command
  class "Chain of Responsibility\nResumeValidationHandler\nNoFabricationValidationHandler\nAtsLengthValidationHandler" as Chain
  class "Template Method\nAbstractTailoringPipeline\nOpenAiTailoringPipeline\nRuleBasedTailoringPipeline" as TemplateMethod
  class "Memento\nResumeVersionMemento\nResumeHistoryCaretaker" as Memento
  class "Mediator\nJobIngestionMediator" as Mediator
  class "Iterator\nResumeSectionIterator" as IteratorPattern
  class "Visitor\nResumeSectionVisitor\nLatexExportVisitor" as Visitor
  class "Null Object\nNullResumeSection" as NullObject
}

FactoryMethod --> AbstractFactory : creates ATS-specific families
AbstractFactory --> Proxy : creates cached/lazy fetchers
Proxy --> Strategy : fetch behavior selected by ATS
Strategy --> Adapter : raw ATS data normalized into internal DTO
Adapter --> Mediator : discovered jobs passed into polling flow
Mediator --> Observer : notifies listeners
Observer --> Facade : downstream resume generation can be triggered
Facade --> TemplateMethod
