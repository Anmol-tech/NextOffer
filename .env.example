# Copy to the repo root as .env and fill in real values. Do not commit .env.
#
# Backend (NextOffer): Spring Boot loads ../.env from the NextOffer module (repo root).
# Frontend (NextOffer-FE): only VITE_* vars are exposed to the client; copy the FE block
#   to NextOffer-FE/.env if you use Vite env files there.

# --- Backend (Spring Boot) ---
SPRING_APPLICATION_NAME=NextOffer

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/next-offer
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# JWT (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# Optional: default is 8080
# SERVER_PORT=8080

# --- Frontend (Vite) ---
# Dev server uses vite proxy to /api -> backend; set this for direct API URL if needed
VITE_API_BASE_URL=http://localhost:8080

# Optional: dev server port (default 5173)
# VITE_DEV_PORT=5173
